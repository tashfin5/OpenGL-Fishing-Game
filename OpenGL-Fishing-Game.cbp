<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="OpenGL-Fishing-Game-v7" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/FishingGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Compiler>
					<Add option="-g" />
					<Add option="-std=gnu++17" />
				</Compiler>
				<Linker>
					<Add library="opengl32" />
					<Add library="glu32" />
					<Add library="freeglut" />
					<Add library="winmm" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/FishingGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-std=gnu++17" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="opengl32" />
					<Add library="glu32" />
					<Add library="freeglut" />
					<Add library="winmm" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="src/main.cpp" />
	</Project>
</CodeBlocks_project_file>
